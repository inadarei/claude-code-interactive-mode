{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "WebSearch(*)",
      "WebFetch(*)"          
    ],
    "ask": [
      "Bash(git*)",
      "Bash(rm*)",
      "Bash(gh*)",      
      "Bash(sudo*)",
      "Bash(brew*)"
    ]
  },
  "hooks": {
      "PostToolUse": [
        {
          "hooks": [
            {
              "type": "command",
              "command": "bash .claude/hooks/check-context-doc.sh"
            }
          ]
        }
      ]
  }
}

